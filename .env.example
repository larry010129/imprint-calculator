# Copy to .env and fill in real values. Loaded automatically via python-dotenv.
# Generate a strong SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Only used the first time the app starts against an empty database, to seed
# the initial admin account. Use a long random value, then change it via the
# admin accounts page and forget it.
ADMIN_PASSWORD=
# 1 = Flask dev server + debugger (never use in production). Leave unset/0 in production.
FLASK_DEBUG=0
PORT=8000
HOST=127.0.0.1
# Optional: overrides the default sqlite:///database.db.
# PostgreSQL example (requires psycopg in requirements.txt):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/diamond_calculator
DATABASE_URL=
# Cloud / production gold price (TWD per gram, 黃金條塊 本行賣出). Update when BOT changes rates.
# Source: https://rate.bot.com.tw/gold/quote/recent
GOLD_XAU_PER_GRAM=
# 1 = skip Playwright/browser scraping. Set to 0 for local dev with playwright installed.
DISABLE_BOT_SCRAPER=0
# 1 = disable background gold price scheduler (use on multi-worker deploys).
DISABLE_PRICE_SCHEDULER=0
# Registration: set REQUIRE_INVITE_CODE=1 and/or REGISTRATION_INVITE_CODE, or use admin /admin/invites
REQUIRE_INVITE_CODE=0
REGISTRATION_INVITE_CODE=
# Production rate limiting (required for multi-process): redis://127.0.0.1:6379
RATELIMIT_STORAGE_URI=
# Reverse-proxy hops to trust for X-Forwarded-* (1 behind nginx, 0 if direct).
TRUSTED_PROXY_COUNT=1
LOG_LEVEL=INFO
# LOG_FILE=/var/log/diamond-calculator/app.log
