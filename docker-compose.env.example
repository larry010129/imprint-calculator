# Copy to .env before running:  copy docker-compose.env.example .env
# Generate SECRET_KEY:  python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me-on-first-run

# Postgres (must match docker-compose db service)
POSTGRES_USER=diamond
POSTGRES_PASSWORD=diamond
POSTGRES_DB=diamond_calculator

# Host port mapped to the web container
PORT=8000

# Production gold price (TWD per gram). Required when DISABLE_BOT_SCRAPER=1.
GOLD_XAU_PER_GRAM=

DISABLE_BOT_SCRAPER=1
DISABLE_PRICE_SCHEDULER=0
REQUIRE_INVITE_CODE=0
TRUSTED_PROXY_COUNT=0
LOG_LEVEL=INFO
