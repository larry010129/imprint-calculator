# Copy to .env on PythonAnywhere:
#   cp deploy/pythonanywhere.env.example .env
# Then fill in SECRET_KEY, ADMIN_PASSWORD, and GOLD_XAU_PER_GRAM.

SECRET_KEY=
ADMIN_PASSWORD=

FLASK_DEBUG=0
DISABLE_BOT_SCRAPER=1
DISABLE_PRICE_SCHEDULER=0

# Current BOT 黃金條塊 sell price (TWD/gram). Update when rates change.
# Source: https://rate.bot.com.tw/gold/quote/recent
GOLD_XAU_PER_GRAM=

# PythonAnywhere sits behind its own HTTPS proxy — keep 1 so sessions/cookies work.
TRUSTED_PROXY_COUNT=1

# Writable absolute SQLite path (four slashes after sqlite:).
DATABASE_URL=sqlite:////home/yuzi010129/calculator/imprint-calculator/database.db

REQUIRE_INVITE_CODE=0
LOG_LEVEL=INFO
